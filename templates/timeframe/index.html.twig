{% extends 'base.html.twig' %}

{% block title %}Timeframe index{% endblock %}

{% block body %}
    <h1>Timeframe index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for timeframe in timeframes %}
            <tr>
                <td>{{ timeframe.id }}</td>
                <td>{{ timeframe.name }}</td>
                <td>
                    <a href="{{ path('app_timeframe_show', {'id': timeframe.id}) }}">show</a>
                    <a href="{{ path('app_timeframe_edit', {'id': timeframe.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_timeframe_new') }}">Create new</a>
{% endblock %}
