{% extends 'base.html.twig' %}

{% block title %}Nouveau Trade - Trading Tracker{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">
                    <i class="bi bi-plus-circle text-primary"></i> Créer un nouveau Trade
                </h1>
                <a href="{{ path('app_trade_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
            </div>

            {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

            <div class="row">
                <!-- Informations de base -->
                <div class="col-lg-6">
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-info-circle"></i> Informations de base
                        </div>
                        <div class="card-body">
                            {{ form_row(form.asset, {'attr': {'class': 'form-control-lg'}}) }}
                            {{ form_row(form.watchlistDate) }}
                            {{ form_row(form.entryDate) }}
                            {{ form_row(form.exitDate) }}
                            {{ form_row(form.orderType) }}
                        </div>
                    </div>
                </div>

                <!-- Gestion du risque -->
                <div class="col-lg-6">
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-graph-up"></i> Gestion du risque
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    {{ form_row(form.riskPercentage) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(form.maxRiskEuro) }}
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    {{ form_row(form.initialRR) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(form.finalRR) }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <!-- Analyse -->
                <div class="col-lg-4">
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-bar-chart"></i> Analyse technique
                        </div>
                        <div class="card-body">
                            {{ form_row(form.timeframes) }}
                            {{ form_row(form.tradeType) }}
                            {{ form_row(form.trend) }}
                        </div>
                    </div>
                </div>

                <!-- Confluences & Setups -->
                <div class="col-lg-4">
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-lightning-charge"></i> Stratégie
                        </div>
                        <div class="card-body">
                            {{ form_row(form.confluences) }}
                            {{ form_row(form.setups) }}
                        </div>
                    </div>
                </div>

                <!-- Résultat -->
                <div class="col-lg-4">
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-trophy"></i> Résultat
                        </div>
                        <div class="card-body">
                            {{ form_row(form.result) }}
                            {{ form_row(form.tradeManagement) }}
                            {{ form_row(form.error) }}
                            {{ form_row(form.goodTrade) }}
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-check-circle"></i> {{ button_label|default('Créer le trade') }}
                </button>
                <a href="{{ path('app_trade_index') }}" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-x-circle"></i> Annuler
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
