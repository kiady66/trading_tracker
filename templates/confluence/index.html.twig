{% extends 'base.html.twig' %}

{% block title %}Confluence index{% endblock %}

{% block body %}
    <h1>Confluence index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for confluence in confluences %}
            <tr>
                <td>{{ confluence.id }}</td>
                <td>{{ confluence.name }}</td>
                <td>
                    <a href="{{ path('app_confluence_show', {'id': confluence.id}) }}">show</a>
                    <a href="{{ path('app_confluence_edit', {'id': confluence.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_confluence_new') }}">Create new</a>
{% endblock %}
