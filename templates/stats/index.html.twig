{% extends 'base.html.twig' %}

{% block title %}Statistiques - Trading Tracker{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>
    <!-- Select2 -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <style>
        .select2-container--bootstrap-5 .select2-selection--multiple {
            min-height: 38px;
        }
        .select2-container--bootstrap-5 .select2-selection--multiple .select2-selection__rendered {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">
                    <i class="bi bi-bar-chart text-primary"></i> Statistiques
                </h1>
            </div>

            <!-- Filtres -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-funnel"></i> Filtres
                </div>
                <div class="card-body">
                    <form method="get" class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Date de début</label>
                            <input type="date" name="start_date" class="form-control"
                                   value="{{ filters.start_date }}">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Date de fin</label>
                            <input type="date" name="end_date" class="form-control"
                                   value="{{ filters.end_date }}">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Confluences</label>
                            <select name="confluences[]" multiple>
                                {% for confluence in all_confluences %}
                                    <option value="{{ confluence.id }}"
                                            {% if confluence.id in filters.confluences|default([]) %}selected{% endif %}>
                                        {{ confluence.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-filter"></i> Appliquer
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Stats Summary -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card stats-card">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Win Rate</h6>
                            <div class="stats-number text-{{ stats.win_rate >= 50 ? 'success' : 'danger' }}">
                                {{ stats.win_rate|default(0)|number_format(1) }}%
                            </div>
                            <small class="text-muted">{{ stats.winning_trades }}W / {{ stats.losing_trades }}L</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Gain Total</h6>
                            <div class="stats-number text-{{ stats.total_gain_euro >= 0 ? 'success' : 'danger' }}">
                                {{ stats.total_gain_euro|default(0)|number_format(2) }} €
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Gain RR Moyen</h6>
                            <div class="stats-number text-{{ stats.avg_gain_rr >= 0 ? 'success' : 'danger' }}">
                                {{ stats.avg_gain_rr|default(0)|number_format(2) }}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Total Trades</h6>
                            <div class="stats-number text-primary">
                                {{ stats.total_trades }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Graphiques -->
            <div class="row mb-4">
                <!-- Win Rate Pie Chart -->
                <div class="col-md-6">
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-pie-chart"></i> Win Rate
                        </div>
                        <div class="card-body">
                            <canvas id="winRateChart" height="250"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Gains RR Bar Chart -->
                <div class="col-md-6">
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-bar-chart"></i> Gains RR par Trade
                        </div>
                        <div class="card-body">
                            <canvas id="gainRRChart" height="250"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <!-- Final RR Bar Chart -->
                <div class="col-md-6">
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-bar-chart"></i> Final RR par Trade
                        </div>
                        <div class="card-body">
                            <canvas id="finalRRChart" height="250"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Gains Line Chart -->
                <div class="col-md-6">
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-graph-up"></i> Évolution des Gains (€)
                        </div>
                        <div class="card-body">
                            <canvas id="gainsChart" height="250"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tableau des stats détaillées -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-table"></i> Statistiques Détaillées
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead class="table-dark">
                            <tr>
                                <th>Métrique</th>
                                <th>Valeur</th>
                                <th>Métrique</th>
                                <th>Valeur</th>
                            </tr>
                            </thead>
                            <tbody>
                            <tr>
                                <td>Nombre total de trades</td>
                                <td class="fw-bold">{{ stats.total_trades }}</td>
                                <td>Gain RR moyen</td>
                                <td class="fw-bold text-{{ stats.avg_gain_rr >= 0 ? 'success' : 'danger' }}">
                                    {{ stats.avg_gain_rr|default(0)|number_format(2) }}
                                </td>
                            </tr>
                            <tr>
                                <td>Trades gagnants</td>
                                <td class="fw-bold text-success">{{ stats.winning_trades }}</td>
                                <td>Gain RR moyen (wins)</td>
                                <td class="fw-bold text-success">
                                    {{ stats.avg_win_rr|default(0)|number_format(2) }}
                                </td>
                            </tr>
                            <tr>
                                <td>Trades perdants</td>
                                <td class="fw-bold text-danger">{{ stats.losing_trades }}</td>
                                <td>Perte RR moyenne (losses)</td>
                                <td class="fw-bold text-danger">
                                    {{ stats.avg_loss_rr|default(0)|number_format(2) }}
                                </td>
                            </tr>
                            <tr>
                                <td>Gain total (€)</td>
                                <td class="fw-bold text-{{ stats.total_gain_euro >= 0 ? 'success' : 'danger' }}">
                                    {{ stats.total_gain_euro|default(0)|number_format(2) }} €
                                </td>
                                <td>Plus gros gain (€)</td>
                                <td class="fw-bold text-success">
                                    {{ stats.max_win_euro|default(0)|number_format(2) }} €
                                </td>
                            </tr>
                            <tr>
                                <td>Gain moyen par trade (€)</td>
                                <td class="fw-bold text-{{ (stats.total_gain_euro / stats.total_trades) >= 0 ? 'success' : 'danger' }}">
                                    {{ stats.total_trades > 0 ? (stats.total_gain_euro / stats.total_trades)|number_format(2) : 0 }} €
                                </td>
                                <td>Plus grosse perte (€)</td>
                                <td class="fw-bold text-danger">
                                    {{ stats.max_loss_euro|default(0)|number_format(2) }} €
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Stats par confluence -->
            {% if confluence_stats|length > 0 %}
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-lightning-charge"></i> Statistiques par Confluence
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead class="table-dark">
                                <tr>
                                    <th>Confluence</th>
                                    <th>Nombre de trades</th>
                                    <th>Win Rate</th>
                                    <th>Gain moyen (€)</th>
                                    <th>RR moyen</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for confluence, data in confluence_stats %}
                                    <tr>
                                        <td class="fw-bold">{{ confluence }}</td>
                                        <td>{{ data.count }}</td>
                                        <td>
                                    <span class="badge bg-{{ data.win_rate >= 50 ? 'success' : 'danger' }}">
                                        {{ data.win_rate|number_format(1) }}%
                                    </span>
                                        </td>
                                        <td class="text-{{ data.avg_gain >= 0 ? 'success' : 'danger' }} fw-bold">
                                            {{ data.avg_gain|number_format(2) }} €
                                        </td>
                                        <td class="text-{{ data.avg_rr >= 0 ? 'success' : 'danger' }} fw-bold">
                                            {{ data.avg_rr|number_format(2) }}
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <!-- jQuery (nécessaire pour Select2) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Select2 -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/i18n/fr.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialisation de Select2 en français
            $('select[name="confluences[]"]').select2({
                theme: 'bootstrap-5',
                placeholder: 'Sélectionnez les confluences',
                allowClear: true,
                width: '100%',
                language: 'fr',
                closeOnSelect: false
            });

            // Win Rate Pie Chart
            const winRateCtx = document.getElementById('winRateChart').getContext('2d');
            new Chart(winRateCtx, {
                type: 'pie',
                data: {
                    labels: ['Gagnants', 'Perdants'],
                    datasets: [{
                        data: [{{ stats.winning_trades }}, {{ stats.losing_trades }}],
                        backgroundColor: ['#28a745', '#dc3545'],
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const label = context.label || '';
                                    const value = context.raw || 0;
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = Math.round((value / total) * 100);
                                    return `${label}: ${value} (${percentage}%)`;
                                }
                            }
                        }
                    }
                }
            });

            // Gains RR Bar Chart
            const gainRRCtx = document.getElementById('gainRRChart').getContext('2d');
            new Chart(gainRRCtx, {
                type: 'bar',
                data: {
                    labels: {{ chart_data.dates|json_encode|raw }},
                    datasets: [{
                        label: 'Gain RR',
                        data: {{ chart_data.gain_rr|json_encode|raw }},
                        backgroundColor: function(context) {
                            const value = context.raw;
                            return value >= 0 ? 'rgba(40, 167, 69, 0.8)' : 'rgba(220, 53, 69, 0.8)';
                        },
                        borderColor: function(context) {
                            const value = context.raw;
                            return value >= 0 ? '#28a745' : '#dc3545';
                        },
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Gain RR'
                            }
                        },
                        x: {
                            display: false
                        }
                    }
                }
            });

            // Final RR Bar Chart
            const finalRRCtx = document.getElementById('finalRRChart').getContext('2d');
            new Chart(finalRRCtx, {
                type: 'bar',
                data: {
                    labels: {{ chart_data.dates|json_encode|raw }},
                    datasets: [{
                        label: 'Final RR',
                        data: {{ chart_data.final_rr|json_encode|raw }},
                        backgroundColor: function(context) {
                            const value = context.raw;
                            return value >= 1 ? 'rgba(40, 167, 69, 0.8)' :
                                value >= 0 ? 'rgba(255, 193, 7, 0.8)' : 'rgba(220, 53, 69, 0.8)';
                        },
                        borderColor: function(context) {
                            const value = context.raw;
                            return value >= 1 ? '#28a745' :
                                value >= 0 ? '#ffc107' : '#dc3545';
                        },
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Final RR'
                            }
                        },
                        x: {
                            display: false
                        }
                    }
                }
            });

            // Gains Line Chart
            const gainsCtx = document.getElementById('gainsChart').getContext('2d');
            new Chart(gainsCtx, {
                type: 'line',
                data: {
                    labels: {{ chart_data.dates|json_encode|raw }},
                    datasets: [{
                        label: 'Gains cumulés (€)',
                        data: {{ chart_data.cumulative_gains|json_encode|raw }},
                        backgroundColor: 'rgba(52, 152, 219, 0.2)',
                        borderColor: '#3498db',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            title: {
                                display: true,
                                text: 'Gains (€)'
                            }
                        },
                        x: {
                            title: {
                                display: true,
                                text: 'Date'
                            }
                        }
                    }
                }
            });
        });
    </script>
{% endblock %}
