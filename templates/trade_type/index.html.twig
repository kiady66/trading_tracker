{% extends 'base.html.twig' %}

{% block title %}TradeType index{% endblock %}

{% block body %}
    <h1>TradeType index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for trade_type in trade_types %}
            <tr>
                <td>{{ trade_type.id }}</td>
                <td>{{ trade_type.name }}</td>
                <td>
                    <a href="{{ path('app_trade_type_show', {'id': trade_type.id}) }}">show</a>
                    <a href="{{ path('app_trade_type_edit', {'id': trade_type.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_trade_type_new') }}">Create new</a>
{% endblock %}
