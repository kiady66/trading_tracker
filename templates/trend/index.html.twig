{% extends 'base.html.twig' %}

{% block title %}Trend index{% endblock %}

{% block body %}
    <h1>Trend index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for trend in trends %}
            <tr>
                <td>{{ trend.id }}</td>
                <td>{{ trend.name }}</td>
                <td>
                    <a href="{{ path('app_trend_show', {'id': trend.id}) }}">show</a>
                    <a href="{{ path('app_trend_edit', {'id': trend.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_trend_new') }}">Create new</a>
{% endblock %}
